# ============================================
# AI Mock Interview Platform — Environment Variables
# ============================================

# ---- Database ----
DATABASE_URL="postgresql://user:password@localhost:5432/ai_mock_interview?schema=public"

# ---- JWT ----
JWT_SECRET="your-jwt-secret-min-32-chars-long-here"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars-long"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- OpenAI ----
OPENAI_API_KEY="sk-..."

# ---- Vapi AI ----
VAPI_API_KEY="your-vapi-private-api-key"
VAPI_PUBLIC_KEY="your-vapi-public-key"

# ---- Server ----
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# ---- Upload ----
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880
