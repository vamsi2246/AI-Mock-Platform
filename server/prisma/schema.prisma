generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & Authentication ───────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  refreshToken  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile            Profile?
  interviewSessions  InterviewSession[]

  @@map("users")
}

model Profile {
  id               String   @id @default(cuid())
  userId           String   @unique
  firstName        String   @default("")
  lastName         String   @default("")
  avatarUrl        String?
  currentRole      String   @default("")
  targetRole       String   @default("")
  yearsExperience  Int      @default(0)
  skills           String   @default("[]")
  resumeUrl        String?
  resumeText       String?
  linkedinUrl      String?
  githubUrl        String?
  preferredDifficulty String @default("intermediate")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── Interview Sessions ───────────────────────────

// Enums mapped to Strings for SQLite compatibility

model InterviewSession {
  id              String          @id @default(cuid())
  userId          String
  type            String
  status          String @default("IN_PROGRESS")
  difficulty      String      @default("INTERMEDIATE")
  duration        Int             @default(1800) // seconds
  actualDuration  Int?
  vapiCallId      String?
  resumeContext   String?
  jobDescription  String?
  startedAt       DateTime        @default(now())
  endedAt         DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     ConversationMessage[]
  report       FeedbackReport?
  scores       SessionScore[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("interview_sessions")
}

// ─── Conversation Messages ────────────────────────

// Enum replaced with String

model ConversationMessage {
  id          String      @id @default(cuid())
  sessionId   String
  role        String
  content     String
  
  // Explainability Metadata
  topic             String?
  difficulty        String?
  evaluationSummary String?
  reasonForFollowUp String?

  timestamp   DateTime    @default(now())
  createdAt   DateTime    @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([timestamp])
  @@map("conversation_messages")
}

// ─── Feedback Reports ─────────────────────────────

model FeedbackReport {
  id                    String   @id @default(cuid())
  sessionId             String   @unique
  overallScore          Float    @default(0)
  communicationScore    Float    @default(0)
  technicalScore        Float    @default(0)
  confidenceScore       Float    @default(0)
  problemSolvingScore   Float    @default(0)
  leadershipScore       Float    @default(0)
  strengths             String @default("[]")
  weaknesses            String @default("[]")
  improvements          String @default("[]")
  hiringRecommendation  String   @default("")
  executiveSummary      String?
  blindSpots            String   @default("[]")
  preparationRoadmap    String?
  summary               String   @default("")
  detailedFeedback      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scores  SessionScore[]

  @@map("feedback_reports")
}

// ─── Session Scores ───────────────────────────────

model SessionScore {
  id         String @id @default(cuid())
  sessionId  String
  reportId   String
  category   String
  score      Float  @default(0)
  maxScore   Float  @default(100)
  notes      String @default("")
  createdAt  DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  report  FeedbackReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([reportId])
  @@map("session_scores")
}
