# ============================================
# AI Mock Interview Platform — Backend Env Example
# ============================================

# ---- Server ----
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.vercel.app

# ---- Database ----
DATABASE_URL="file:/opt/data/dev.db"

# ---- JWT Authentication ----
JWT_SECRET=your-jwt-access-secret-32-chars-long
JWT_REFRESH_SECRET=your-jwt-refresh-secret-32-chars-long

# ---- OpenAI ----
OPENAI_API_KEY=your-openai-api-key

# ---- Vapi Voice AI ----
VAPI_API_KEY=your-vapi-private-key
VAPI_PUBLIC_KEY=your-vapi-public-key
VAPI_ASSISTANT_ID=optional-vapi-assistant-id
